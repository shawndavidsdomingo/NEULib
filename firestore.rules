rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminByEmail() {
      return isSignedIn()
        && request.auth.token.email == 'shawndavidsobremontedomingo@gmail.com';
    }

    function isAdminByDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['admin', 'super_admin'];
    }

    function isSuperAdminByDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             == 'super_admin';
    }

    function isAdminOrSuper() {
      return isAdminByEmail() || isAdminByDoc();
    }

    function isSuperAdmin() {
      return isAdminByEmail() || isSuperAdminByDoc();
    }

    // ── /users ───────────────────────────────────────────────────────────────
    // Kiosk reads users to identify students (may be unauthenticated briefly)
    match /users/{userId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
                      request.auth.uid == userId || isAdminOrSuper()
                    );
      allow delete: if isAdminOrSuper();
    }

    // ── /library_logs ────────────────────────────────────────────────────────
    // Kiosk reads logs to check existing sessions; writes check-in/out
    match /library_logs/{logId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdminOrSuper();
    }

    // ── /departments ─────────────────────────────────────────────────────────
    // Kiosk reads departments for dropdown; registration page reads before login
    match /departments/{docId} {
      allow read:   if true;
      allow write:  if isAdminOrSuper();
    }

    // ── /programs ────────────────────────────────────────────────────────────
    match /programs/{docId} {
      allow read:   if true;
      allow write:  if isAdminOrSuper();
    }

    // ── /visit_purposes ──────────────────────────────────────────────────────
    // Kiosk reads active purposes for the check-in dropdown
    match /visit_purposes/{docId} {
      allow read:   if true;
      allow write:  if isAdminOrSuper();
    }

    // ── /announcements ───────────────────────────────────────────────────────
    // Kiosk shows announcements on idle screen before any auth
    match /announcements/{docId} {
      allow read:   if true;
      allow write:  if isSignedIn(); // UI gates to admin role; isAdminOrSuper() can fail for regular admins
    }

    // ── /branches ────────────────────────────────────────────────────────────
    // Kiosk reads branch schedule for auto-checkout
    match /branches/{docId} {
      allow read:   if true;
      allow write:  if isSuperAdmin();
    }

    // ── /blocked_attempts ────────────────────────────────────────────────────
    match /blocked_attempts/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdminOrSuper();
    }

    // ── /audit_logs ──────────────────────────────────────────────────────────
    // Only super admins can read audit logs; all admins can create (write-only audit trail)
    match /audit_logs/{docId} {
      allow read:   if isSuperAdmin();
      allow create: if isAdminOrSuper();
      allow update, delete: if false;
    }

    // ── /credential_requests ─────────────────────────────────────────────────
    match /credential_requests/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdminOrSuper();
      allow delete: if isAdminOrSuper();
    }

    // ── /goals ───────────────────────────────────────────────────────────────
    match /goals/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn();
    }

    // ── /scheduled_reports ───────────────────────────────────────────────────
    // Readable/writable by any signed-in user — UI gates access to admin role only
    // isAdminOrSuper() uses get() which can fail for regular admins on first load
    match /scheduled_reports/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn();
    }
  }
}
